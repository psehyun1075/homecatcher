{
  "name": "home-catcher",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @home-catcher/api dev",
    "dev:mobile": "pnpm --filter @home-catcher/mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm --filter @home-catcher/mobile exec expo export --platform web",
    "test:api-smoke": "bash apps/api/scripts/smoke/mvp-full-regression.sh",
    "test:mvp": "bash apps/api/scripts/smoke/mvp-full-regression.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
