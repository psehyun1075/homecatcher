# API 서버 바인딩 주소입니다. 로컬 기본값은 0.0.0.0입니다.
API_HOST="0.0.0.0"
# API 서버 포트입니다. 로컬 기본값은 3000입니다.
API_PORT=3000

# PostgreSQL과 Redis 연결 정보입니다.
DATABASE_URL="postgresql://homecatcher:homecatcher@localhost:5432/homecatcher"
REDIS_URL="redis://localhost:6379"

# 개발용 예시입니다. 운영 환경에서는 충분히 긴 별도 secret을 사용하세요.
JWT_ACCESS_SECRET="replace-me-with-a-long-development-secret"
JWT_REFRESH_SECRET="replace-me-with-a-different-long-development-secret"

# 상품 URL 미리보기 요청 timeout(ms)입니다. 잘못된 값이면 서버는 안전한 기본값 5000ms를 사용합니다.
PRODUCT_PREVIEW_TIMEOUT_MS=5000

# Expo Web 개발에서 허용할 origin입니다. 쉼표로 여러 origin을 지정할 수 있습니다.
# 운영 환경에서는 *를 사용하지 마세요.
CORS_ORIGINS="http://localhost:19006,http://127.0.0.1:19006"

# Expo 앱이 사용할 API 기본 URL입니다. 로컬 실기기 테스트 시 LAN IP로 바꿔주세요.
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000/api/v1"
