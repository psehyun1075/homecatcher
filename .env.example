# API 서버 바인딩 주소입니다. 기본값은 0.0.0.0입니다.
API_HOST="0.0.0.0"
# API 서버 포트입니다. 기본값은 3000입니다.
API_PORT=3000
DATABASE_URL="postgresql://homecatcher:homecatcher@localhost:5432/homecatcher"
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me"
REDIS_URL="redis://localhost:6379"
PRODUCT_PREVIEW_TIMEOUT_MS=5000
# Expo 앱이 사용할 API 기본 URL입니다. 로컬 실기기 테스트 시 LAN IP로 바꿔주세요.
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"
